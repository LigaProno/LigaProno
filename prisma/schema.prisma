generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  clerkId             String               @unique
  email               String               @unique
  firstName           String?
  lastName            String?
  imageUrl            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TournamentMember[]
  tournaments         Tournament[]         @relation("CreatedTournaments")
  wcMatchPredictions  WcMatchPrediction[]
  wcExtraPredictions  WcExtraPrediction[]
}

// Competiție activă în party: null = fără pronosticuri; altfel `{COD_API}_{anSezon}` (ex. WC_2026, PL_2024) din Football-Data.
model Tournament {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  inviteCode           String               @unique
  creatorId            String               @db.ObjectId
  creator              User                 @relation("CreatedTournaments", fields: [creatorId], references: [id])
  members              TournamentMember[]
  competition          String?
  // Dacă false: pronosticurile se blochează după startul competiției. Dacă true: se pot modifica, cu penalizare per schimbare.
  allowPredictionChangesDuringCompetition Boolean            @default(false)
  wcMatchPredictions   WcMatchPrediction[]
  wcExtraPredictions   WcExtraPrediction[]
  bettingOdds          TournamentBettingOdds?
  lastManualOddsRefreshAt DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

// Snapshot cote (OddsPortal / Gemini) folosit la punctaj: bază × cotă pentru rezultatul real.
model TournamentBettingOdds {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @unique @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payload      Json
  oddsSource   String?
  geminiModel  String?
  fetchedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Pronostic pe meci (pauză, final, scor). matchId = id Football-Data.org.
model WcMatchPrediction {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId  String     @db.ObjectId
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  userId        String     @db.ObjectId
  user          User       @relation(fields: [userId], references: [id])
  matchId       Int
  htOutcome     String?
  ftOutcome     String?
  predHomeGoals Int?
  predAwayGoals Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([tournamentId, userId, matchId])
  @@index([tournamentId])
}

// Calificări din grupe + campion. advancingTeamIds = id-uri echipe Football-Data.
model WcExtraPrediction {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId       String     @db.ObjectId
  tournament         Tournament @relation(fields: [tournamentId], references: [id])
  userId             String     @db.ObjectId
  user               User       @relation(fields: [userId], references: [id])
  advancingTeamIds   Int[]
  championTeamId     Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

model TournamentMember {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  userId       String     @db.ObjectId
  user         User       @relation(fields: [userId], references: [id])
  joinedAt     DateTime   @default(now())
  // Număr de salvări care au modificat pronosticul după startul competiției (10 pct fiecare).
  midCompetitionPredictionChangeCount Int @default(0)
  // Cached scores — populated by the refresh-scores cron, read by the leaderboard.
  cachedFg             Int       @default(0)
  cachedPg             Int       @default(0)
  cachedSc             Int       @default(0)
  cachedCg             Int       @default(0)
  cachedChampionPoints Int       @default(0)
  cachedChangePenalty  Int       @default(0)
  cachedTotal          Int       @default(0)
  scoreUpdatedAt       DateTime?

  @@unique([tournamentId, userId])
}

// Știri zilnice CM 2026 pentru dashboard (Gemini + Google Search).
model DashboardNewsSnapshot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  dateKey     String   @unique
  items       Json
  geminiModel String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
