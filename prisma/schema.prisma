generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  clerkId             String               @unique
  email               String               @unique
  firstName           String?
  lastName            String?
  imageUrl            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TournamentMember[]
  tournaments         Tournament[]         @relation("CreatedTournaments")
  wcMatchPredictions  WcMatchPrediction[]
  wcExtraPredictions  WcExtraPrediction[]
}

// Competiție activă în party: null = fără pronosticuri; altfel `{COD_API}_{anSezon}` (ex. WC_2026, PL_2024) din Football-Data.
model Tournament {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  inviteCode           String               @unique
  creatorId            String               @db.ObjectId
  creator              User                 @relation("CreatedTournaments", fields: [creatorId], references: [id])
  members              TournamentMember[]
  competition          String?
  // Dacă false: pronosticurile se blochează după startul competiției. Dacă true: se pot modifica, cu penalizare per schimbare.
  allowPredictionChangesDuringCompetition Boolean            @default(false)
  wcMatchPredictions   WcMatchPrediction[]
  wcExtraPredictions   WcExtraPrediction[]
  bettingOdds          TournamentBettingOdds?
  liga1Fixtures        Liga1Fixture[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

// Snapshot cote (Gemini) folosit la punctaj: bază × cotă pentru rezultatul real.
model TournamentBettingOdds {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @unique @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payload      Json
  geminiModel  String?
  fetchedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Pronostic pe meci (pauză, final, scor). matchId = id Football-Data.org.
model WcMatchPrediction {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId  String     @db.ObjectId
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  userId        String     @db.ObjectId
  user          User       @relation(fields: [userId], references: [id])
  matchId       Int
  htOutcome     String?
  ftOutcome     String?
  predHomeGoals Int?
  predAwayGoals Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([tournamentId, userId, matchId])
  @@index([tournamentId])
}

// Calificări din grupe + campion. advancingTeamIds = id-uri echipe Football-Data.
model WcExtraPrediction {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId       String     @db.ObjectId
  tournament         Tournament @relation(fields: [tournamentId], references: [id])
  userId             String     @db.ObjectId
  user               User       @relation(fields: [userId], references: [id])
  advancingTeamIds   Int[]
  championTeamId     Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

model Liga1Fixture {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId    String     @db.ObjectId
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  internalMatchId Int
  matchday        Int
  homeTeamId      Int
  homeTeamName    String
  awayTeamId      Int
  awayTeamName    String
  utcDate         DateTime
  htFetchAt       DateTime
  ftFetchAt       DateTime
  status          String     @default("SCHEDULED")
  htHome          Int?
  htAway          Int?
  ftHome          Int?
  ftAway          Int?
  geminiConfident Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([tournamentId, internalMatchId])
  @@index([tournamentId])
  @@index([status])
}

model TournamentMember {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  userId       String     @db.ObjectId
  user         User       @relation(fields: [userId], references: [id])
  joinedAt     DateTime   @default(now())
  // Număr de salvări care au modificat pronosticul după startul competiției (10 pct fiecare).
  midCompetitionPredictionChangeCount Int @default(0)

  @@unique([tournamentId, userId])
}

// Știri zilnice CM 2026 pentru dashboard (Gemini + Google Search).
model DashboardNewsSnapshot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  dateKey     String   @unique
  items       Json
  geminiModel String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
