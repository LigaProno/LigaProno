generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  clerkId             String               @unique
  email               String               @unique
  firstName           String?
  lastName            String?
  imageUrl            String?
  favoriteTeamId      Int?
  favoriteTeamName    String?
  favoriteTeamCrest   String?
  favoriteTeamCompetition String?
  // Cel mai lung șir de scoruri exacte la rând (turnee publice) — calculat de cronul refresh-scores.
  cachedBestStreak    Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         TournamentMember[]
  tournaments         Tournament[]         @relation("CreatedTournaments")
  wcMatchPredictions  WcMatchPrediction[]
  wcExtraPredictions  WcExtraPrediction[]
  miniGamePlays       MiniGamePlay[]
  supportMessages     SupportMessage[]
  tournamentWins      TournamentWin[]
}

// Competiție activă în party: null = fără pronosticuri; altfel `{COD_API}_{anSezon}` (ex. WC_2026, PL_2024) din Football-Data.
model Tournament {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  inviteCode           String               @unique
  creatorId            String               @db.ObjectId
  creator              User                 @relation("CreatedTournaments", fields: [creatorId], references: [id])
  members              TournamentMember[]
  competition          String?
  // Gameweek window: null = whole tournament. Set at creation time from current matchday.
  startMatchday        Int?
  endMatchday          Int?
  // Dacă false: pronosticurile se blochează după startul competiției. Dacă true: se pot modifica, cu penalizare per schimbare.
  allowPredictionChangesDuringCompetition Boolean            @default(false)
  isPublic             Boolean            @default(false)
  prizes               Json?
  wcMatchPredictions   WcMatchPrediction[]
  wcExtraPredictions   WcExtraPrediction[]
  bettingOdds          TournamentBettingOdds?
  lastManualOddsRefreshAt DateTime?
  // Setat de cron când toate meciurile din fereastra turneului s-au terminat.
  // Odată setat, clasamentul e final și badge-ul nu se mai recalculează.
  closedAt             DateTime?
  win                  TournamentWin?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

// Stadion + oră (scraping OddsPortal) per meci, partajat per competiție — populat o singură dată.
model CompetitionMatchVenues {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  competition String   @unique
  venues      Json
  source      String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Snapshot cote partajat de toate party-urile aceleiași competiții (ex. WC_2026).
model CompetitionBettingOdds {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  competition           String   @unique
  payload               Json
  oddsSource            String?
  geminiModel           String?
  fetchedAt             DateTime @default(now())
  lastManualRefreshAt   DateTime?
  updatedAt             DateTime @updatedAt
}

// Snapshot cote per party (legacy) — citire doar ca fallback până la migrare.
model TournamentBettingOdds {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @unique @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payload      Json
  oddsSource   String?
  geminiModel  String?
  fetchedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Pronostic pe meci (pauză, final, scor). matchId = id Football-Data.org.
model WcMatchPrediction {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId  String     @db.ObjectId
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  userId        String     @db.ObjectId
  user          User       @relation(fields: [userId], references: [id])
  matchId       Int
  htOutcome     String?
  ftOutcome     String?
  predHomeGoals Int?
  predAwayGoals Int?
  /** Echipă aleasă să avanseze (meciuri eliminatorii). */
  predAdvancingTeamId Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([tournamentId, userId, matchId])
  @@index([tournamentId])
}

// Calificări din grupe + campion. advancingTeamIds = id-uri echipe Football-Data.
model WcExtraPrediction {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId       String     @db.ObjectId
  tournament         Tournament @relation(fields: [tournamentId], references: [id])
  userId             String     @db.ObjectId
  user               User       @relation(fields: [userId], references: [id])
  advancingTeamIds   Int[]
  championTeamId     Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

model TournamentMember {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @db.ObjectId
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  userId       String     @db.ObjectId
  user         User       @relation(fields: [userId], references: [id])
  joinedAt     DateTime   @default(now())
  // Număr de salvări care au modificat pronosticul după startul competiției (10 pct fiecare).
  midCompetitionPredictionChangeCount Int @default(0)
  // Cached scores — populated by the refresh-scores cron, read by the leaderboard.
  cachedFg             Int       @default(0)
  cachedPg             Int       @default(0)
  cachedSc             Int       @default(0)
  cachedCg             Int       @default(0)
  cachedChampionPoints Int       @default(0)
  cachedChangePenalty  Int       @default(0)
  cachedTotal          Int       @default(0)
  scoreUpdatedAt       DateTime?

  @@unique([tournamentId, userId])
}

// Știri zilnice CM 2026 pentru dashboard (Gemini + Google Search).
model DashboardNewsSnapshot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  dateKey     String   @unique
  items       Json
  geminiModel String?
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Progres zilnic mini jocuri (trivia, campion ascuns, bingo) — dateKey = ziua în Europe/Bucharest.
model MiniGamePlay {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @db.ObjectId
  user                User     @relation(fields: [userId], references: [id])
  dateKey             String
  triviaAnswers       Int[]
  triviaScore         Int      @default(0)
  triviaCompleted     Boolean  @default(false)
  championGuesses     String[]
  championSolved      Boolean  @default(false)
  championScore       Int      @default(0)
  bingoCells          Json?
  bingoMoves          Int      @default(0)
  bingoWastedMoves    Int      @default(0)
  bingoLineComplete   Boolean  @default(false)
  bingoFullHouse      Boolean  @default(false)
  bingoScore          Int      @default(0)
  totalScore          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, dateKey])
  @@index([dateKey])
  @@index([userId])
}

// Mesaje trimise din formularul de support; citite din panoul de admin.
model SupportMessage {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  // Autorul rămâne legat de user ca să putem urmări cine a scris, chiar dacă schimbă numele/emailul din formular.
  userId      String?             @db.ObjectId
  user        User?               @relation(fields: [userId], references: [id])
  name        String
  email       String
  category    SupportCategory
  message     String
  status      SupportStatus       @default(OPEN)
  seenAt      DateTime?
  resolvedAt  DateTime?
  comments    SupportComment[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([category])
  @@index([userId])
}

// Răspuns de la admin pe un tichet; userul îl vede în pagina de support.
model SupportComment {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  messageId  String         @db.ObjectId
  message    SupportMessage @relation(fields: [messageId], references: [id])
  body       String
  createdAt  DateTime       @default(now())

  @@index([messageId])
}

enum SupportCategory {
  BUG
  QUESTION
  SUGGESTION
  OTHER
}

enum SupportStatus {
  OPEN
  SEEN
  DONE
}

// Badge câștigat la un turneu public. Snapshot: odată acordat nu se recalculează,
// chiar dacă scorurile se schimbă ulterior (cotele se actualizează zilnic).
model TournamentWin {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  userId        String     @db.ObjectId
  user          User       @relation(fields: [userId], references: [id])
  tournamentId  String     @db.ObjectId
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  // Numele turneului la momentul câștigării — supraviețuiește redenumirii.
  tournamentName String
  // Scorul final îngheţat, pentru tooltip/istoric.
  finalTotal    Float
  awardedAt     DateTime   @default(now())

  @@unique([tournamentId])
  @@index([userId])
}
